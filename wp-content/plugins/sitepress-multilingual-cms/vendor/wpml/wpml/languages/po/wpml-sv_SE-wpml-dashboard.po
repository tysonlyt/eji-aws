msgstr "En del av innehållet du vill översätta är redan översatt"

msgid "What do you want to do with the content that's already translated?"
msgstr "Vad vill du göra med innehållet som redan är översatt?"

msgid "Suggested deadline:"
msgstr "Föreslagen deadline:"

msgid "Set a batch name and deadline"
msgstr "Ange ett batchnamn och en deadline"

msgid "You can assign a custom name to this batch for easy tracking and suggest a deadline to clarify the priority for translators."
msgstr "Du kan tilldela ett anpassat namn till denna batch för enkel spårning och föreslå en deadline för att klargöra prioriteten för översättare."

msgid "Batch name:"
msgstr "Batchnamn:"

msgid "Default translation engine: "
msgstr "Standardöversättningsmotor: "

msgid "Change"
msgstr "Ändra"

msgid "Failed to load engines"
msgstr "Kunde inte ladda motorer"

msgid "No engines enabled"
msgstr "Inga motorer aktiverade"

msgid "In order to assign yourself as translator, you first need to <add_yourself>add yourself as %s translator</add_yourself> to the site.<br/> Add yourself as %s translator and click <check_again>check again</check_again> or choose a different translation option."
msgstr "För att tilldela dig själv som översättare måste du först <add_yourself>lägga till dig själv som %s översättare</add_yourself> till webbplatsen.<br/> Lägg till dig själv som %s översättare och klicka på <check_again>kontrollera igen</check_again> eller välj ett annat översättningsalternativ."

msgid "In order to assign yourself as translator, you first need to <add_yourself>add yourself as %s to %s translator</add_yourself> to the site.<br/> Add yourself as %s to %s translator and click <check_again>check again</check_again> or choose a different translation option."
msgstr "För att tilldela dig själv som översättare måste du först <add_yourself>lägga till dig själv som %s till %s översättare</add_yourself> till webbplatsen.<br/> Lägg till dig själv som %s till %s översättare och klicka på <check_again>kontrollera igen</check_again> eller välj ett annat översättningsalternativ."

msgid "Checking"
msgstr "Kontrollerar"

msgid "In order to assign a translation service, you first need to <activate_ts>activate a translation service</activate_ts>.<br/>Activate a translation service and click <check_again>check again</check_again> or choose a different translation option."
msgstr "För att tilldela en översättningstjänst måste du först <activate_ts>aktivera en översättningstjänst</activate_ts>.<br/>Aktivera en översättningstjänst och klicka på <check_again>kontrollera igen</check_again> eller välj ett annat översättningsalternativ."

msgid " Checking "
msgstr " Kontrollerar "

msgid "In order to translate automatically, you first need to <enable_ate>enable WPML's Advanced Translation Editor</enable_ate>.<br/>Enable the Advanced Translation Editor and click <check_again>check again</check_again> or choose a different translation option."
msgstr "För att översätta automatiskt måste du först <enable_ate>aktivera WPML:s avancerade översättningsredigerare</enable_ate>.<br/>Aktivera den avancerade översättningsredigeraren och klicka på <check_again>kontrollera igen</check_again> eller välj ett annat översättningsalternativ."

msgid "Selected content was translated using the Classic Translation Editor and can't be sent for automatic translation. To allow this, enable \"Use also for old translations\" in <wpmlSettingLink>WPML Settings</wpmlSettingLink> page."
msgstr "Valt innehåll översattes med den klassiska översättningsredigeraren och kan inte skickas för automatisk översättning. För att tillåta detta, aktivera “Använd även för gamla översättningar” på sidan <wpmlSettingLink>WPML-inställningar</wpmlSettingLink>."

