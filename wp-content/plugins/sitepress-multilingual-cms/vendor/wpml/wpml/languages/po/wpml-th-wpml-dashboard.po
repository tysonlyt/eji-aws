msgstr "คุณมี %s เครดิต — ต้องการอีก %s เพื่อแปลเนื้อหานี้"

msgid "You’re missing %s credits for the translation jobs in progress — %s are needed in total"
msgstr "คุณขาด %s เครดิตสำหรับงานแปลที่กำลังดำเนินการอยู่ — ต้องการทั้งหมด %s"

msgid "Summary:"
msgstr "สรุป:"

msgid "Credit"
msgid_plural "Credits"
msgstr[0] "เครดิต"

msgid "€%1$s approximately"
msgstr "ประมาณ €%1$s"

msgid "Pricing"
msgstr "ราคา"

msgid "Your Automatic Translation Credits"
msgstr "เครดิตการแปลอัตโนมัติของคุณ"

msgid "To proceed with translation, activate Pay-As-You-Go or assign prepaid credits."
msgstr "หากต้องการดำเนินการแปล ให้เปิดใช้งานจ่ายตามที่คุณไป หรือมอบหมายเครดิตแบบเติมเงิน"

msgid "Leave existing translations as they are"
msgstr "คงการแปลที่มีอยู่ไว้ตามเดิม"

msgid "Overwrite existing translations"
msgstr "เขียนทับการแปลที่มีอยู่"

