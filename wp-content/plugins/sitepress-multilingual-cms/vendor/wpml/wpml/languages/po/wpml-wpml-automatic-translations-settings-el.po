msgid "Could not fetch engines data"
msgstr "Δεν ήταν δυνατή η ανάκτηση δεδομένων μηχανών"

msgid "Could not save settings"
msgstr "Δεν ήταν δυνατή η αποθήκευση των ρυθμίσεων"

msgid "Automatic translation"
msgstr "Αυτόματη μετάφραση"

msgid "Saving..."
msgstr "Αποθήκευση..."

msgid "Save settings"
msgstr "Αποθήκευση ρυθμίσεων"

msgid "Settings saved"
msgstr "Οι ρυθμίσεις αποθηκεύτηκαν"

msgid "Some error occurred"
msgstr "Παρουσιάστηκε κάποιο σφάλμα"

msgid "AI Translation"
msgstr "Μετάφραση ΤΝ"

msgid "Don't translate drafts. Only translate when I publish content."
msgstr "Να μην μεταφράζονται τα πρόχειρα. Να μεταφράζονται μόνο όταν δημοσιεύω περιεχόμενο."

msgid "Translate drafts as I save them (consumes a bit more translation credits)."
msgstr "Να μεταφράζονται τα πρόχειρα καθώς τα αποθηκεύω (καταναλώνει λίγο περισσότερες μονάδες μετάφρασης)."

msgid "Do you want to translate drafts automatically?"
msgstr "Θέλετε να μεταφράζετε αυτόματα τα πρόχειρα;"

msgid "This feature is only available when you enable \"Translate Everything Automatically\" from the %sTranslation Dashboard%s."
msgstr "Αυτή η λειτουργία είναι διαθέσιμη μόνο όταν ενεργοποιήσετε την επιλογή “Μετάφραση όλων αυτόματα” από τον %sΠίνακα ελέγχου μετάφρασης%s."

msgid "What would you like to do after WPML finishes translating your content automatically?"
msgstr "Τι θα θέλατε να κάνετε αφού το WPML ολοκληρώσει την αυτόματη μετάφραση του περιεχομένου σας;"

msgid "Publish without review"
msgstr "Δημοσίευση χωρίς έλεγχο"

msgid "Recommended with PTC"
msgstr "Συνιστάται με PTC"

msgid "PTC provides Better Than Human Translations that rarely need improvements, so you can confidently skip the review process. For other translation engines, a human review is recommended to confirm accuracy."
msgstr "Το PTC παρέχει μεταφράσεις καλύτερες από ανθρώπινες που σπάνια χρειάζονται βελτιώσεις, ώστε να μπορείτε να παραλείψετε με σιγουριά τη διαδικασία ελέγχου. Για άλλες μηχανές μετάφρασης, συνιστάται ανθρώπινος έλεγχος για επιβεβαίωση της ακρίβειας."

msgid "WPML publishes translations immediately, skipping the review process."
msgstr "Το WPML δημοσιεύει τις μεταφράσεις αμέσως, παραλείποντας τη διαδικασία ελέγχου."

msgid "Wait for review"
msgstr "Αναμονή για έλεγχο"

msgid "Recommended with DeepL, Google and Microsoft"
msgstr "Συνιστάται με DeepL, Google και Microsoft"

msgid "DeepL, Google, and Microsoft deliver great translations, but we recommend a human review to confirm they are correct. PTC provides Better Than Human Translations that understand context, so you can confidently skip the review process."
msgstr "Οι DeepL, Google και Microsoft παρέχουν εξαιρετικές μεταφράσεις, αλλά συνιστούμε ανθρώπινο έλεγχο για να επιβεβαιωθεί ότι είναι σωστές. Το PTC παρέχει μεταφράσεις καλύτερες από ανθρώπινες που κατανοούν το περιεχόμενο, ώστε να μπορείτε να παραλείψετε με σιγουριά τη διαδικασία ελέγχου."

msgid "WPML keeps translations unpublished, so you can review them first."
msgstr "Το WPML διατηρεί τις μεταφράσεις μη δημοσιευμένες, ώστε να μπορείτε να τις ελέγξετε πρώτα."

msgid "Your translators review and approve translations before publishing."
msgstr "Οι μεταφραστές σας ελέγχουν και εγκρίνουν τις μεταφράσεις πριν από τη δημοσίευση."

msgid "Publish and mark for review"
msgstr "Δημοσίευση και επισήμανση για έλεγχο"

msgid "WPML publishes translations immediately but flags them for you to check at your convenience."
msgstr "Το WPML δημοσιεύει τις μεταφράσεις αμέσως, αλλά τις επισημαίνει για να τις ελέγξετε όποτε σας βολεύει."

msgid "WPML publishes translations immediately but flags them for translators to review later."
msgstr "Το WPML δημοσιεύει τις μεταφράσεις αμέσως, αλλά τις επισημαίνει για να τις ελέγξουν οι μεταφραστές αργότερα."
