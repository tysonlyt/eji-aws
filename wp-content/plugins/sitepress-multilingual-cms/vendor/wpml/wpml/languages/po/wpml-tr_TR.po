#: src/config-admin-pages.php:383
msgid "WPML Setup"
msgstr "WPML Kurulumu"

#: src/config-admin-pages.php:412
msgid "WPML Support"
msgstr "WPML Desteği"

#: src/Core/Component/MinimumRequirements/Domain/Entity/DatabaseVersionRequirement.php:27
msgid "Database Version"
msgstr "Veritabanı sürümü"

#: src/Core/Component/MinimumRequirements/Domain/Entity/DatabaseVersionRequirement.php:36
msgid "Your %sMySQL%s version must be at least %s. Alternatively, you can use %sMariaDb%s version %s or higher."
msgstr "%sMySQL%s sürümünüz en az %s olmalıdır. Alternatif olarak, %sMariaDb%s sürüm %s veya daha yüksek kullanabilirsiniz."

#: src/Core/Component/MinimumRequirements/Domain/Entity/DatabaseVersionRequirement.php:53
msgid "Contact your hosting provider to upgrade MySQL %s or higher."
msgstr "MySQL %s veya daha yüksek bir sürüme yükseltmek için barındırma sağlayıcınızla iletişime geçin."

#: src/Core/Component/MinimumRequirements/Domain/Entity/EvalFunctionRequirement.php:31
msgid "PHP eval() Function"
msgstr "PHP eval() Fonksiyonu"

#: src/Core/Component/MinimumRequirements/Domain/Entity/EvalFunctionRequirement.php:39
msgid "The PHP eval() function is disabled by the Suhosin extension. WPML requires this function when Suhosin is enabled."
msgstr "PHP eval() fonksiyonu Suhosin uzantısı tarafından devre dışı bırakılmıştır. WPML, Suhosin etkinleştirildiğinde bu fonksiyona ihtiyaç duyar."

#: src/Core/Component/MinimumRequirements/Domain/Entity/EvalFunctionRequirement.php:47
msgid "Contact your hosting provider to enable the eval() function in the Suhosin configuration or disable the Suhosin extension."
msgstr "Suhosin yapılandırmasında eval() fonksiyonunu etkinleştirmek veya Suhosin uzantısını devre dışı bırakmak için barındırma sağlayıcınızla iletişime geçin."

#: src/Core/Component/MinimumRequirements/Domain/Entity/LibXmlVersionRequirement.php:31
msgid "libxml PHP Module"
msgstr "libxml PHP Modülü"

#: src/Core/Component/MinimumRequirements/Domain/Entity/LibXmlVersionRequirement.php:40
msgid "WPML requires libxml PHP Module version %s or higher to process XML correctly using SimpleXML."
msgstr "WPML, SimpleXML kullanarak XML'i doğru şekilde işlemek için libxml PHP Modülü sürüm %s veya daha yüksek bir sürüme ihtiyaç duyar."

#: src/Core/Component/MinimumRequirements/Domain/Entity/LibXmlVersionRequirement.php:49
msgid "Contact your hosting provider to upgrade the libxml PHP Module."
msgstr "libxml PHP Modülünü yükseltmek için barındırma sağlayıcınızla iletişime geçin."

#: src/Core/Component/MinimumRequirements/Domain/Entity/MbstringExtensionRequirement.php:30
msgid "Multibyte String Extension"
msgstr "Çok baytlı dize uzantısı"

#: src/Core/Component/MinimumRequirements/Domain/Entity/MbstringExtensionRequirement.php:39
msgid "The %sMultibyte String extension%s is required to handle non-Latin character sets in WPML."
msgstr "WPML'de Latin olmayan karakter kümelerini işlemek için %sÇok Baytlı Dize uzantısı%s gereklidir."

#: src/Core/Component/MinimumRequirements/Domain/Entity/MbstringExtensionRequirement.php:49
msgid "Contact your hosting provider to install the Multibyte String (mbstring) PHP extension."
msgstr "Çok Baytlı Dize (mbstring) PHP uzantısını yüklemek için barındırma sağlayıcınızla iletişime geçin."

#: src/Core/Component/MinimumRequirements/Domain/Entity/MemoryLimitRequirement.php:55
msgid "Memory limit"
msgstr "Bellek sınırı"

#: src/Core/Component/MinimumRequirements/Domain/Entity/MemoryLimitRequirement.php:65
msgid "Your PHP memory limit is currently %s.  WPML requires at least %s to function properly."
msgstr "PHP bellek sınırınız şu anda %s. WPML'nin düzgün çalışması için en az %s gereklidir."

#: src/Core/Component/MinimumRequirements/Domain/Entity/MemoryLimitRequirement.php:80
msgid "To increase the memory limit, add this to the top of your %swp-config.php%s file:"
msgstr "Bellek sınırını artırmak için, %swp-config.php%s dosyanızın en üstüne şunu ekleyin:"

#: src/Core/Component/MinimumRequirements/Domain/Entity/PHPVersionRequirement.php:25
msgid "PHP Version"
msgstr "PHP sürümü"

#: src/Core/Component/MinimumRequirements/Domain/Entity/PHPVersionRequirement.php:34
msgid "Your PHP version is outdated. WPML requires at least %s."
msgstr "PHP sürümünüz güncel değil. WPML en az %s gerektirir."

#: src/Core/Component/MinimumRequirements/Domain/Entity/PHPVersionRequirement.php:44
msgid "Contact your hosting provider to upgrade PHP to version %s or higher."
msgstr "PHP'yi %s veya daha yüksek bir sürüme yükseltmek için barındırma sağlayıcınızla iletişime geçin."

#: src/Core/Component/MinimumRequirements/Domain/Entity/RestEnabledRequirement.php:31
msgid "WordPress REST API"
msgstr "WordPress REST API"

#: src/Core/Component/MinimumRequirements/Domain/Entity/RestEnabledRequirement.php:41
msgid "The WordPress REST API must be enabled for WPML to work correctly."
msgstr "WPML'nin doğru çalışması için WordPress REST API etkinleştirilmelidir."

#: src/Core/Component/MinimumRequirements/Domain/Entity/RestEnabledRequirement.php:49
msgid "The REST API test endpoint %s is not responding correctly."
msgstr "REST API test uç noktası %s doğru yanıt vermiyor."

#: src/Core/Component/MinimumRequirements/Domain/Entity/RestEnabledRequirement.php:58
msgid "<strong>Common causes:</strong>"
msgstr "<strong>Yaygın nedenler:</strong>"

#: src/Core/Component/MinimumRequirements/Domain/Entity/RestEnabledRequirement.php:65
msgid "• A security or firewall plugin is blocking REST API requests<br>• The REST API has been disabled via the <code>rest_enabled</code> filter<br>• Server configuration (Apache/Nginx) is interfering with query parameters<br>• Custom rewrite rules are conflicting with WordPress routing"
msgstr "• Bir güvenlik veya güvenlik duvarı eklentisi REST API isteklerini engelliyor<br>• REST API, <code>rest_enabled</code> filtresi aracılığıyla devre dışı bırakıldı<br>• Sunucu yapılandırması (Apache/Nginx) sorgu parametreleriyle çakışıyor<br>• Özel yeniden yazma kuralları WordPress yönlendirmesiyle çakışıyor"

#: src/Core/Component/MinimumRequirements/Domain/Entity/RestEnabledRequirement.php:79
msgid "<strong>Troubleshooting:</strong> Try accessing %s directly in your browser. It should return a JSON response with <code>\"status\":\"valid\"</code> and <code>\"get_parameters\":\"valid\"</code>."
msgstr "<strong>Sorun giderme:</strong> %s'ya doğrudan tarayıcınızdan erişmeyi deneyin. <code>“status”:“valid”</code> ve <code>“get_parameters”:“valid”</code> içeren bir JSON yanıtı döndürmelidir."

#: src/Core/Component/MinimumRequirements/Domain/Entity/RestEnabledRequirement.php:87
msgid "the test endpoint"
msgstr "test uç noktası"

#: src/Core/Component/MinimumRequirements/Domain/Entity/SimpleXMLExtensionRequirement.php:31
msgid "SimpleXML Extension"
msgstr "SimpleXML uzantısı"

#: src/Core/Component/MinimumRequirements/Domain/Entity/SimpleXMLExtensionRequirement.php:40
msgid "The %sSimpleXML extension%s is required to use %sXLIFF files%s in WPML. The libxml PHP Module must also be version 2.7.8 or higher."
msgstr "WPML'de %sXLIFF dosyalarını%s kullanmak için %sSimpleXML uzantısı%s gereklidir. libxml PHP Modülü de 2.7.8 veya daha yüksek bir sürüm olmalıdır."

#: src/Core/Component/MinimumRequirements/Domain/Entity/SimpleXMLExtensionRequirement.php:55
msgid "Contact your hosting provider to install the SimpleXML PHP extension."
msgstr "SimpleXML PHP uzantısını yüklemek için barındırma sağlayıcınızla iletişime geçin."

#: src/Core/Component/MinimumRequirements/Domain/Entity/StackSizeRequirement.php:39
msgid "PHP Stack Size"
msgstr "PHP yığın boyutu"

#: src/Core/Component/MinimumRequirements/Domain/Entity/StackSizeRequirement.php:48
msgid "WPML requires at least %s KB of PHP stack size on PHP 8.3 or higher."
msgstr "WPML, PHP 8.3 veya daha yüksek sürümlerde en az %s KB PHP yığın boyutuna ihtiyaç duyar."

#: src/Core/Component/MinimumRequirements/Domain/Entity/StackSizeRequirement.php:58
msgid "Add this to your %sphp.ini%s and restart your web server to set the required stack size:"
msgstr "Gerekli yığın boyutunu ayarlamak için bunu %sphp.ini%s dosyanıza ekleyin ve web sunucunuzu yeniden başlatın:"

#: src/Core/Component/MinimumRequirements/Domain/Entity/WordPressVersionRequirement.php:30
msgid "WordPress Version"
msgstr "WordPress sürümü"

#: src/Core/Component/MinimumRequirements/Domain/Entity/WordPressVersionRequirement.php:39
msgid "Your WordPress version is outdated. WPML requires at least %s. "
msgstr "WordPress sürümünüz güncel değil. WPML en az %s gerektirir. "

#: src/Core/Component/MinimumRequirements/Domain/Entity/WordPressVersionRequirement.php:50
msgid "Please update your WordPress installation to version %s or higher."
msgstr "Lütfen WordPress kurulumunuzu %s veya daha yüksek bir sürüme güncelleyin."

