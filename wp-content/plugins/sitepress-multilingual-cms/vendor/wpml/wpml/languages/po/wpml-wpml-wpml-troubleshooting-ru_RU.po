msgid "Alias Domain"
msgstr "Домен-псевдоним"

msgid "If you didn't change your main domain and only logged in through an alias domain, you can register it here. WPML will then use the original domain for API communication with AMS."
msgstr "Если вы не меняли свой основной домен и входили в систему только через домен-псевдоним, вы можете зарегистрировать его здесь. WPML будет использовать исходный домен для связи с AMS через API."

msgid "Something went wrong. Please try again."
msgstr "Что-то пошло не так. Пожалуйста, попробуйте еще раз."

msgid "Registering..."
msgstr "Регистрация..."

msgid "Register current domain as alias"
msgstr "Зарегистрировать текущий домен как псевдоним"

msgid "The current domain has been registered as an alias domain."
msgstr "Текущий домен зарегистрирован как домен-псевдоним."

msgid "Current alias domains:"
msgstr "Текущие домены-псевдонимы:"

msgid "This will remove all registered alias domains. If you are accessing this site through an alias domain, the migration banner will appear again."
msgstr "Это удалит все зарегистрированные домены-псевдонимы. Если вы заходите на этот сайт через домен-псевдоним, баннер миграции появится снова."

msgid "Resetting..."
msgstr "Сброс..."

msgid "Reset alias domains"
msgstr "Сбросить домены-псевдонимы"

msgid "Alias domains have been reset."
msgstr "Домены-псевдонимы сброшены."

msgid "PostHog Integration"
msgstr "Интеграция с PostHog"

msgid "PostHog is running on your site"
msgstr "PostHog работает на вашем сайте"

msgid "Enable PostHog to help us improve our product"
msgstr "Включите PostHog, чтобы помочь нам улучшить наш продукт"

msgid "your PostHog session ID is: "
msgstr "ваш идентификатор сеанса PostHog: "
