msgid "Your site now meets WPML's minimum requirements"
msgstr "האתר שלך עומד כעת בדרישות המינימום של WPML"

msgid "Start WPML Setup"
msgstr "התחל בהגדרת WPML"

msgid "Need Help?"
msgstr "זקוק לעזרה?"

msgid "Contact our support team"
msgstr "צור קשר עם צוות התמיכה שלנו"

msgid " and we'll guide you through it step by step."
msgstr " ונדריך אותך צעד אחר צעד."

msgid "Your site doesn't meet WPML's minimum requirements"
msgstr "האתר שלך אינו עומד בדרישות המינימום של WPML"

msgid "Ensure your site runs smoothly with WPML by meeting these simple minimum requirements."
msgstr "ודא שהאתר שלך פועל בצורה חלקה עם WPML על ידי עמידה בדרישות המינימום הפשוטות הללו."

msgid "Re-check Now"
msgstr "בדוק שוב עכשיו"

msgid "Skip for now"
msgstr "דלג לעת עתה"
