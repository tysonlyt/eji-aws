msgid "In order to assign yourself as translator, you first need to <add_yourself>add yourself as %s translator</add_yourself> to the site.<br/> Add yourself as %s translator and click <check_again>check again</check_again> or choose a different translation option."
msgstr "Para se atribuir como tradutor, você precisa primeiro <add_yourself>adicionar-se como tradutor de %s</add_yourself> ao site.<br/> Adicione-se como tradutor de %s e clique em <check_again>verificar novamente</check_again> ou escolha uma opção de tradução diferente."

msgid "In order to assign yourself as translator, you first need to <add_yourself>add yourself as %s to %s translator</add_yourself> to the site.<br/> Add yourself as %s to %s translator and click <check_again>check again</check_again> or choose a different translation option."
msgstr "Para se atribuir como tradutor, você precisa primeiro <add_yourself>adicionar-se como tradutor de %s para %s</add_yourself> ao site.<br/> Adicione-se como tradutor de %s para %s e clique em <check_again>verificar novamente</check_again> ou escolha uma opção de tradução diferente."

msgid "Checking"
msgstr "Verificando"

msgid "In order to assign a translation service, you first need to <activate_ts>activate a translation service</activate_ts>.<br/>Activate a translation service and click <check_again>check again</check_again> or choose a different translation option."
msgstr "Para atribuir um serviço de tradução, você precisa primeiro <activate_ts>ativar um serviço de tradução</activate_ts>.<br/>Ative um serviço de tradução e clique em <check_again>verificar novamente</check_again> ou escolha uma opção de tradução diferente."

msgid " Checking "
msgstr " Verificando "

msgid "In order to translate automatically, you first need to <enable_ate>enable WPML's Advanced Translation Editor</enable_ate>.<br/>Enable the Advanced Translation Editor and click <check_again>check again</check_again> or choose a different translation option."
msgstr "Para traduzir automaticamente, você precisa primeiro <enable_ate>ativar o Editor de Tradução Avançado do WPML</enable_ate>.<br/>Ative o Editor de Tradução Avançado e clique em <check_again>verificar novamente</check_again> ou escolha uma opção de tradução diferente."

msgid "Selected content was translated using the Classic Translation Editor and can't be sent for automatic translation. To allow this, enable \"Use also for old translations\" in <wpmlSettingLink>WPML Settings</wpmlSettingLink> page."
msgstr "O conteúdo selecionado foi traduzido usando o Editor de Tradução Clássico e não pode ser enviado para tradução automática. Para permitir isso, ative “Usar também para traduções antigas” na página <wpmlSettingLink>Configurações do WPML</wpmlSettingLink>."

msgid "Some of the selected content was translated using the Classic Translation Editor and can't be sent for automatic translation. To allow this, enable \"Use also for old translations\" in <wpmlSettingLink>WPML Settings</wpmlSettingLink> page."
msgstr "Parte do conteúdo selecionado foi traduzido usando o Editor de Tradução Clássico e não pode ser enviado para tradução automática. Para permitir isso, ative “Usar também para traduções antigas” na página <wpmlSettingLink>Configurações do WPML</wpmlSettingLink>."

msgid ""
"Any existing content (translations) will be overwritten when creating duplicates.\n"
