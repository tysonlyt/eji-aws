msgstr "Compre um %1$spacote pré-pago%2$s com pelo menos %3$s%4$s créditos%5$s e atribua-os a este site."

msgid "This amount will cover translation of all your current content."
msgstr "Este valor cobrirá a tradução de todo o seu conteúdo atual."

msgid "Assign at least %1$s%2$s credits%3$s to this site to continue."
msgstr "Atribua pelo menos %1$s%2$s créditos%3$s a este site para continuar."

msgid "Assign credits from your WPML account and buy an additional %1$sprepaid package%2$s with at least %3$s%4$s credits%5$s credits to cover the remaining amount."
msgstr "Atribua créditos da sua conta WPML e compre um %1$spacote pré-pago%2$s adicional com pelo menos %3$s%4$s créditos%5$s para cobrir o valor restante."

msgid "Prepaid credits"
