msgstr[0] "%d tradução restante na fila..."
msgstr[1] "%d traduções restantes na fila..."

msgid "Translate Everything Automatically has finished translating your content. There are no pending translations in the queue."
msgstr "Traduzir Tudo Automaticamente terminou de traduzir o seu conteúdo. Não há traduções pendentes na fila."

msgid "Some items were translated using the Classic Translation Editor and cannot be sent for automatic translation. Please select these items and choose the option to translate them yourself."
msgstr "Alguns itens foram traduzidos usando o Editor de Tradução Clássico e não podem ser enviados para tradução automática. Selecione estes itens e escolha a opção de os traduzir você mesmo."

msgid "Translate Everything Automatically - enabled"
msgstr "Traduzir Tudo Automaticamente - ativado"

msgid "Translate Everything Automatically is enabled"
msgstr "Traduzir Tudo Automaticamente está ativado"

msgid "As you create new content or edit existing content, WPML will automatically translate it, but only from %s to %s."
msgstr "À medida que criar novo conteúdo ou editar conteúdo existente, o WPML irá traduzi-lo automaticamente, mas apenas de %s para %s."

msgid "Translate Everything Automatically is paused — payment required"
msgstr "A tradução automática de tudo está em pausa — pagamento necessário"

msgid "Automatic translation is paused — payment required"
msgstr "Tradução automática em pausa — pagamento necessário"

msgid "Automatic translation - payment required"
msgstr "Tradução automática - pagamento necessário"

msgid "We couldn’t process payment for your completed translations. Click “Pay now” to retry and continue using automatic translation."
msgstr "Não foi possível processar o pagamento das suas traduções concluídas. Clique em “Pagar agora” para tentar novamente e continuar a usar a tradução automática."

msgid "Cancel translation"
msgstr "Cancelar tradução"

msgid "Translate Everything Automatically is paused — not enough credits"
msgstr "A tradução automática de tudo está em pausa — créditos insuficientes"

msgid "Automatic translation is paused — not enough credits"
msgstr "Tradução automática em pausa — créditos insuficientes"

msgid "Translation will resume automatically after you assign more credits."
msgstr "A tradução será retomada automaticamente depois de atribuir mais créditos."

msgid "This item needs a translation update but can't be translated automatically because it was translated with the Classic Translation Editor."
msgstr "Este item precisa de uma atualização de tradução, mas não pode ser traduzido automaticamente porque foi traduzido com o Editor de Tradução Clássico."

msgid "This item needs update. Please, select the item and send for translation."
msgstr "Este item precisa de atualização. Por favor, selecione o item e envie para tradução."

msgid "Translations completed with the Classic Translation Editor cannot be sent for automatic translation"
msgstr "As traduções concluídas com o Editor de Tradução Clássico não podem ser enviadas para tradução automática"

