msgstr "Traduzir Tudo Automaticamente - desativado"

msgid "Translate Everything Automatically"
msgstr "Traduzir tudo automaticamente"

msgid "Automatically translate all %s content to %s."
msgstr "Traduzir automaticamente todo o conteúdo %s para %s."

