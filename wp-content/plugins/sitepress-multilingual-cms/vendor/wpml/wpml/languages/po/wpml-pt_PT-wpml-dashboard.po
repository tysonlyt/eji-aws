msgstr "Traduzir Tudo Automaticamente - a pausar"

msgid "Translate Everything Automatically is pausing"
msgstr "Traduzir Tudo Automaticamente está a pausar"

msgid "Translate Everything Automatically - paused"
msgstr "Traduzir Tudo Automaticamente - pausado"

msgid "%d translation left in the queue. Preparing more content for translation."
msgid_plural "%d translations left in the queue. Preparing more content for translation."
msgstr[0] "%d tradução restante na fila. A preparar mais conteúdo para tradução."
msgstr[1] "%d traduções restantes na fila. A preparar mais conteúdo para tradução."

