msgstr "يكلف محتوى الموقع الحالي %1$sحوالي %2$s يورو%3$s للترجمة."

msgid "The selected content costs %1$sapproximately €%2$s%3$s to translate."
msgstr "يكلف المحتوى المحدد %1$sحوالي %2$s يورو%3$s للترجمة."

msgid "Pay-As-You-Go"
msgstr "الدفع أولاً بأول"

msgid "Activate Pay-As-You-Go to translate automatically with monthly billing."
msgstr "قم بتفعيل الدفع أولاً بأول للترجمة التلقائية مع الفواتير الشهرية."

msgid "Activate Pay-As-You-Go"
