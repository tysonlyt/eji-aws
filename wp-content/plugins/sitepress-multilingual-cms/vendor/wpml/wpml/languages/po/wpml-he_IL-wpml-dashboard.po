msgid "The following target languages do not support automatic translation: %s. <a>Map to known languages</a> to enable automatic translation."
msgstr "שפות היעד הבאות אינן תומכות בתרגום אוטומטי: %s. <a>מפה לשפות ידועות</a> כדי לאפשר תרגום אוטומטי."

msgid "The site's default language %s doesn't support automatic translation."
msgstr "שפת ברירת המחדל של האתר %s אינה תומכת בתרגום אוטומטי."

msgid "Some sections are hidden due to current filter settings or because they have no items. <show_all>Show all translation statuses</show_all>"
msgstr "חלק מהמקטעים מוסתרים עקב הגדרות סינון נוכחיות או מכיוון שאין בהם פריטים. <show_all>הצג את כל סטטוסי התרגום</show_all>"

