msgid "This item was translated using the WordPress Editor. Switching to the WPML's Translation Editor will overwrite the existing translation."
msgstr "פריט זה תורגם באמצעות עורך וורדפרס. מעבר לעורך התרגום של WPML יחליף את התרגום הקיים."

msgid "This item needs a translation update but was previously translated using the WordPress Editor. Using the WPML's Translation Editor will overwrite the existing translation."
msgstr "פריט זה דורש עדכון תרגום אך תורגם בעבר באמצעות עורך וורדפרס. שימוש בעורך התרגום של WPML יחליף את התרגום הקיים."

msgid "This item hasn't been translated yet and is set to use the WordPress Editor."
msgstr "פריט זה עדיין לא תורגם והוא מוגדר להשתמש בעורך וורדפרס."

