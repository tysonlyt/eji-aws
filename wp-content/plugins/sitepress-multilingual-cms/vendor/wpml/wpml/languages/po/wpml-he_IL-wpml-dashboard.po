msgstr "קצה קדמי (נצפה)"

msgid "Backend (viewed)"
msgstr "קצה אחורי (נצפה)"

msgid "Unknown"
msgstr "לא ידוע"

msgid "Search string or a name"
msgstr "חפש מחרוזת או שם"

msgid "All Translation Priorities"
msgstr "כל עדיפויות התרגום"

msgid "This filter is available only if source is set to \"Frontend\" or \"Backend\"."
msgstr "מסנן זה זמין רק אם המקור מוגדר ל-\"קצה קדמי\" או \"קצה אחורי\"."

msgid "front-end"
msgstr "קצה קדמי"

msgid "back-end"
msgstr "קצה אחורי"

msgid "viewed"
msgstr "נצפה"

msgid "Strings in the theme and plugins"
msgstr "מחרוזות בערכת הנושא ובתוספים"

msgid "Translate front-end texts you can customize from the WordPress admin like footer text, copyright notices, plugin options and settings, time format, widget texts, and more."
msgstr "תרגם טקסטים בחזית האתר שניתן להתאים אישית מלוח הניהול של וורדפרס, כגון טקסט תחתון, הודעות זכויות יוצרים, אפשרויות והגדרות תוספים, פורמט זמן, טקסטים של ווידג'טים ועוד."

msgid "Translating Strings From Admin and Settings"
msgstr "תרגום מחרוזות מממשק הניהול וההגדרות"

msgid "Translate texts in admin screens"
msgstr "תרגם טקסטים במסכי הניהול"

msgid "Translate User Meta Information"
msgstr "תרגם מידע מטא של משתמשים"

msgid "Making User Meta Information Translatable"
msgstr "הפיכת מידע מטא של משתמשים לניתן לתרגום"

msgid "Translate user profile strings"
msgstr "תרגם מחרוזות פרופיל משתמש"

msgid "You need to visit translations on your site's front-end (<a/>) and WPML will identify all untranslated strings and list them here. "
msgstr "עליך לבקר בתרגומים בקצה הקדמי של האתר שלך (<a/>) ו-WPML יזהה את כל המחרוזות הלא מתורגמות וירשום אותן כאן. "

msgid "hide details"
msgstr "הסתר פרטים"

msgid "more details"
msgstr "פרטים נוספים"

msgid "Still can't find the strings you're looking to translate? Add more strings for translation."
msgstr "עדיין לא מוצא את המחרוזות שאתה מחפש לתרגם? הוסף מחרוזות נוספות לתרגום."

msgid "Not seeing strings that you are looking for?"
msgstr "לא רואה את המחרוזות שאתה מחפש?"

msgid "Enable the autoregistration setting."
msgstr "הפעל את הגדרת הרישום האוטומטי."

msgid "Visit translations on the site's frontend for WPML to see which strings are missing translations. Visiting one language is enough: %s."
msgstr "בקר בתרגומים בחזית האתר עבור WPML כדי לראות אילו מחרוזות חסרות תרגומים. ביקור בשפה אחת מספיק: %s."

msgid "Alternatively, you can register strings manually."
msgstr "לחלופין, תוכל לרשום מחרוזות ידנית."

msgid "Translate Everything translates only those strings which are registered in English language"
msgstr "תרגם הכל מתרגם רק את המחרוזות הרשומות בשפה האנגלית"

msgid "Most strings from your plugins and theme are in English, so we’re showing them alongside your default language. Use the <b>Source Language</b> filter to view strings in a specific language."
msgstr "רוב המחרוזות מהתוספים והערכה שלך הן באנגלית, ולכן אנו מציגים אותן לצד שפת ברירת המחדל שלך. השתמש במסנן <b>שפת מקור</b> כדי להציג מחרוזות בשפה ספציפית."

msgid "You’re using <b>%s</b> to cache your site, which may prevent WPML from automatically registering new strings. To fix this, clear your page cache, then visit your translated pages again on the frontend to detect new strings."
msgstr "אתה משתמש ב-<b>%s</b> כדי לשמור את האתר שלך במטמון, מה שעשוי למנוע מ-WPML לרשום מחרוזות חדשות באופן אוטומטי. כדי לתקן זאת, נקה את מטמון הדף שלך, ולאחר מכן בקר שוב בדפים המתורגמים שלך בקצה הקדמי כדי לזהות מחרוזות חדשות."

msgid "WPML can detect strings that appear on the site and list them here. This feature helps you identify the strings that actually appear on the site and translate them. To see here only the strings that actually appear on the site, you need to enable this feature."
msgstr "WPML יכול לזהות מחרוזות המופיעות באתר ולרשום אותן כאן. תכונה זו עוזרת לך לזהות את המחרוזות שמופיעות בפועל באתר ולתרגם אותן. כדי לראות כאן רק את המחרוזות שמופיעות בפועל באתר, עליך להפעיל תכונה זו."

msgid "WPML detects strings that appear on the site and lists them here. This feature helps you identify the strings that actually appear on the site and translate them. To see here all the strings in the site, you need to disable this feature."
msgstr "WPML מזהה מחרוזות המופיעות באתר ורושם אותן כאן. תכונה זו עוזרת לך לזהות את המחרוזות שמופיעות בפועל באתר ולתרגם אותן. כדי לראות כאן את כל המחרוזות באתר, עליך להשבית תכונה זו."

msgid "Detect untranslated strings"
msgstr "זהה מחרוזות לא מתורגמות"

msgid "WPML can detect untranslated strings and automatically register them for translation. This happens in real time as you or your visitors browse your website."
msgstr "WPML יכול לזהות מחרוזות לא מתורגמות ולרשום אותן אוטומטית לתרגום. זה קורה בזמן אמת כשאתה או המבקרים שלך גולשים באתר שלך."

msgid "Automatically register untranslated strings"
msgstr "רשום אוטומטית מחרוזות לא מתורגמות"

msgid "Learn how to use auto-registration"
msgstr "למד כיצד להשתמש ברישום אוטומטי"

msgid "recommended"
msgstr "מומלץ"

msgid "Also register strings from the website's back-end"
msgstr "רשום גם מחרוזות מהקצה האחורי של האתר"

msgid "Save settings"
msgstr "שמור הגדרות"

msgid "Request failed because of the network error"
msgstr "הבקשה נכשלה עקב שגיאת רשת"

msgid "Try again"
msgstr "נסה שוב"

msgid "Enabled"
msgstr "מופעל"

msgid "Disabled"
msgstr "מושבת"

msgid "Modify"
msgstr "שנה"

msgid "You can only translate %1$s from the site's default language (%2$s)."
msgstr "אתה יכול לתרגם רק %1$s משפת ברירת המחדל של האתר (%2$s)."

msgid "%1sCheck pricing%2s."
msgstr "%1sבדוק מחירים%2s."

msgid "The current site content costs %1$sapproximately €%2$s%3$s to translate."
msgstr "תרגום תוכן האתר הנוכחי עולה %1$sכ-€%2$s%3$s."

msgid "The selected content costs %1$sapproximately €%2$s%3$s to translate."
msgstr "תרגום התוכן הנבחר עולה %1$sכ-€%2$s%3$s."

msgid "Pay-As-You-Go"
msgstr "Pay-As-You-Go"

msgid "Activate Pay-As-You-Go to translate automatically with monthly billing."
msgstr "הפעל את Pay-As-You-Go כדי לתרגם אוטומטית עם חיוב חודשי."

msgid "Activate Pay-As-You-Go"
msgstr "הפעל את Pay-As-You-Go"

msgid "Already using Pay-As-You-Go on another site?"
msgstr "כבר משתמש ב-Pay-As-You-Go באתר אחר?"

msgid "Connect this site to it"
msgstr "חבר את האתר הזה אליו"

msgid "Buy and assign credits"
msgstr "קנה והקצה קרדיטים"

msgid "Buy a %1$sprepaid package%2$s with at least %3$s%4$s credits%5$s and assign them to this site."
msgstr "קנה %1$sחבילה משולמת מראש%2$s עם לפחות %3$s%4$s נקודות זכות%5$s והקצה אותן לאתר זה."

