msgid "WPML does not support duplicating strings."
msgstr "WPML אינו תומך בשכפול מחרוזות."

msgid "WPML does not support duplicating %1$s elements."
msgstr "WPML אינו תומך בשכפול %1$s אלמנטים."

msgid "WPML does not support duplicating %1$s elements and strings."
