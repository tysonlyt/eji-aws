msgid "This filter is available only if source is set to \"Frontend\" or \"Backend\"."
msgstr "Bộ lọc này chỉ khả dụng nếu nguồn được đặt thành “Giao diện người dùng” hoặc “Phần phụ trợ”."

msgid "front-end"
msgstr "giao diện người dùng"

msgid "back-end"
msgstr "phần phụ trợ"

msgid "viewed"
msgstr "đã xem"

msgid "Strings in the theme and plugins"
msgstr "Chuỗi trong giao diện và plugin"

msgid "Translate front-end texts you can customize from the WordPress admin like footer text, copyright notices, plugin options and settings, time format, widget texts, and more."
msgstr "Dịch các văn bản giao diện người dùng mà bạn có thể tùy chỉnh từ quản trị WordPress như văn bản chân trang, thông báo bản quyền, tùy chọn và cài đặt plugin, định dạng thời gian, văn bản tiện ích, v.v."

msgid "Translating Strings From Admin and Settings"
msgstr "Dịch chuỗi từ quản trị và cài đặt"

msgid "Translate texts in admin screens"
msgstr "Dịch văn bản trong màn hình quản trị"

msgid "Translate User Meta Information"
msgstr "Dịch thông tin meta người dùng"

msgid "Making User Meta Information Translatable"
msgstr "Làm cho thông tin meta người dùng có thể dịch được"

msgid "Translate user profile strings"
msgstr "Dịch chuỗi hồ sơ người dùng"

msgid "You need to visit translations on your site's front-end (<a/>) and WPML will identify all untranslated strings and list them here. "
msgstr "Bạn cần truy cập các bản dịch trên giao diện người dùng của trang web (<a/>) và WPML sẽ xác định tất cả các chuỗi chưa dịch và liệt kê chúng ở đây. "

msgid "hide details"
msgstr "ẩn chi tiết"

msgid "more details"
msgstr "thêm chi tiết"

msgid "Still can't find the strings you're looking to translate? Add more strings for translation."
msgstr "Vẫn không tìm thấy các chuỗi bạn muốn dịch? Thêm nhiều chuỗi hơn để dịch."

msgid "Not seeing strings that you are looking for?"
msgstr "Không thấy các chuỗi bạn đang tìm kiếm?"

msgid "Enable the autoregistration setting."
msgstr "Bật cài đặt tự động đăng ký."

msgid "Visit translations on the site's frontend for WPML to see which strings are missing translations. Visiting one language is enough: %s."
msgstr "Truy cập bản dịch trên giao diện người dùng của trang web cho WPML để xem những chuỗi nào bị thiếu bản dịch. Chỉ cần truy cập một ngôn ngữ là đủ: %s."

msgid "Alternatively, you can register strings manually."
msgstr "Ngoài ra, bạn có thể đăng ký chuỗi thủ công."

msgid "Translate Everything translates only those strings which are registered in English language"
msgstr "Dịch mọi thứ chỉ dịch những chuỗi được đăng ký bằng tiếng Anh"

msgid "Most strings from your plugins and theme are in English, so we’re showing them alongside your default language. Use the <b>Source Language</b> filter to view strings in a specific language."
msgstr "Hầu hết các chuỗi từ plugin và giao diện của bạn đều bằng tiếng Anh, vì vậy chúng tôi hiển thị chúng cùng với ngôn ngữ mặc định của bạn. Sử dụng bộ lọc <b>Ngôn ngữ nguồn</b> để xem các chuỗi bằng một ngôn ngữ cụ thể."

msgid "You’re using <b>%s</b> to cache your site, which may prevent WPML from automatically registering new strings. To fix this, clear your page cache, then visit your translated pages again on the frontend to detect new strings."
msgstr "Bạn đang sử dụng <b>%s</b> để lưu vào bộ nhớ đệm trang web của mình, điều này có thể ngăn WPML tự động đăng ký các chuỗi mới. Để khắc phục điều này, hãy xóa bộ nhớ đệm trang của bạn, sau đó truy cập lại các trang đã dịch của bạn trên giao diện người dùng để phát hiện các chuỗi mới."

msgid "WPML can detect strings that appear on the site and list them here. This feature helps you identify the strings that actually appear on the site and translate them. To see here only the strings that actually appear on the site, you need to enable this feature."
msgstr "WPML có thể phát hiện các chuỗi xuất hiện trên trang web và liệt kê chúng ở đây. Tính năng này giúp bạn xác định các chuỗi thực sự xuất hiện trên trang web và dịch chúng. Để chỉ xem các chuỗi thực sự xuất hiện trên trang web ở đây, bạn cần bật tính năng này."

msgid "WPML detects strings that appear on the site and lists them here. This feature helps you identify the strings that actually appear on the site and translate them. To see here all the strings in the site, you need to disable this feature."
msgstr "WPML phát hiện các chuỗi xuất hiện trên trang web và liệt kê chúng ở đây. Tính năng này giúp bạn xác định các chuỗi thực sự xuất hiện trên trang web và dịch chúng. Để xem tất cả các chuỗi trên trang web ở đây, bạn cần tắt tính năng này."

msgid "Detect untranslated strings"
msgstr "Phát hiện chuỗi chưa dịch"

msgid "WPML can detect untranslated strings and automatically register them for translation. This happens in real time as you or your visitors browse your website."
msgstr "WPML có thể phát hiện các chuỗi chưa dịch và tự động đăng ký chúng để dịch. Điều này xảy ra trong thời gian thực khi bạn hoặc khách truy cập của bạn duyệt trang web của bạn."

msgid "Automatically register untranslated strings"
msgstr "Tự động đăng ký chuỗi chưa dịch"

msgid "Learn how to use auto-registration"
msgstr "Tìm hiểu cách sử dụng tự động đăng ký"

msgid "recommended"
msgstr "được đề xuất"

msgid "Also register strings from the website's back-end"
msgstr "Cũng đăng ký chuỗi từ phần phụ trợ của trang web"

msgid "Save settings"
msgstr "Lưu cài đặt"

msgid "Request failed because of the network error"
msgstr "Yêu cầu không thành công do lỗi mạng"

msgid "Try again"
msgstr "Thử lại"

msgid "Enabled"
msgstr "Đã bật"

msgid "Disabled"
msgstr "Đã tắt"

msgid "Modify"
msgstr "Sửa đổi"

msgid "You can only translate %1$s from the site's default language (%2$s)."
msgstr "Bạn chỉ có thể dịch %1$s từ ngôn ngữ mặc định của trang web (%2$s)."

msgid "%1sCheck pricing%2s."
msgstr "%1sKiểm tra giá%2s."

msgid "The current site content costs %1$sapproximately €%2$s%3$s to translate."
msgstr "Nội dung trang web hiện tại có chi phí dịch khoảng %1$s€%2$s%3$s."

msgid "The selected content costs %1$sapproximately €%2$s%3$s to translate."
msgstr "Nội dung đã chọn có chi phí dịch khoảng %1$s€%2$s%3$s."

msgid "Pay-As-You-Go"
msgstr "Trả tiền cho những gì bạn tiêu thụ"

msgid "Activate Pay-As-You-Go to translate automatically with monthly billing."
msgstr "Kích hoạt Trả tiền cho những gì bạn tiêu thụ để dịch tự động với thanh toán hàng tháng."

msgid "Activate Pay-As-You-Go"
msgstr "Kích hoạt Trả tiền cho những gì bạn tiêu thụ"

msgid "Already using Pay-As-You-Go on another site?"
msgstr "Đã sử dụng Trả tiền cho những gì bạn tiêu thụ trên một trang web khác?"

msgid "Connect this site to it"
msgstr "Kết nối trang web này với nó"

msgid "Buy and assign credits"
msgstr "Mua và gán tín dụng"

msgid "Buy a %1$sprepaid package%2$s with at least %3$s%4$s credits%5$s and assign them to this site."
msgstr "Mua một %1$sgói trả trước%2$s với ít nhất %3$s%4$s tín dụng%5$s và gán chúng cho trang web này."

msgid "This amount will cover translation of all your current content."
msgstr "Số tiền này sẽ bao gồm chi phí dịch tất cả nội dung hiện tại của bạn."

msgid "Assign at least %1$s%2$s credits%3$s to this site to continue."
