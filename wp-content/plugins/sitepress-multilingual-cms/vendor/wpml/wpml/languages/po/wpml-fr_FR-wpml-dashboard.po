msgstr "La traduction du contenu sélectionné coûte %1$senviron %2$s €%3$s."

msgid "Pay-As-You-Go"
msgstr "Paiement à l’utilisation"

msgid "Activate Pay-As-You-Go to translate automatically with monthly billing."
msgstr "Activez le paiement à l’utilisation pour traduire automatiquement avec une facturation mensuelle."

msgid "Activate Pay-As-You-Go"
msgstr "Activer le paiement à l’utilisation"

msgid "Already using Pay-As-You-Go on another site?"
msgstr "Vous utilisez déjà le paiement à l’utilisation sur un autre site ?"

msgid "Connect this site to it"
msgstr "Connecter ce site à celui-ci"

msgid "Buy and assign credits"
msgstr "Acheter et attribuer des crédits"

msgid "Buy a %1$sprepaid package%2$s with at least %3$s%4$s credits%5$s and assign them to this site."
msgstr "Achetez un %1$spack prépayé%2$s avec au moins %3$s%4$s crédits%5$s et attribuez-les à ce site."

msgid "This amount will cover translation of all your current content."
msgstr "Ce montant couvrira la traduction de tout votre contenu actuel."

msgid "Assign at least %1$s%2$s credits%3$s to this site to continue."
msgstr "Attribuez au moins %1$s%2$s crédits%3$s à ce site pour continuer."

msgid "Assign credits from your WPML account and buy an additional %1$sprepaid package%2$s with at least %3$s%4$s credits%5$s credits to cover the remaining amount."
msgstr "Attribuez des crédits de votre compte WPML et achetez un %1$spack prépayé%2$s supplémentaire avec au moins %3$s%4$s crédits%5$s pour couvrir le montant restant."

msgid "Prepaid credits"
msgstr "Crédits prépayés"

msgid "There are %1$s%2$s available on your WPML account.%3$s"
msgstr "Il y a %1$s%2$s disponibles sur votre compte WPML.%3$s"

msgid "(Only the WPML account owner can do this.)"
msgstr "(Seul le propriétaire du compte WPML peut le faire.)"

msgid "Checking for new credits..."
msgstr "Vérification des nouveaux crédits..."

msgid "Still not enough credits. Refresh again in %d seconds."
msgstr "Toujours pas assez de crédits. Actualisez à nouveau dans %d secondes."

msgid "Already assigned?"
msgstr "Déjà attribué?"

