msgid "translation error"
msgstr "erreur de traduction"

msgid "This item was translated using the WordPress Editor. Switching to the WPML's Translation Editor will overwrite the existing translation."
msgstr "Cet élément a été traduit à l’aide de l’éditeur WordPress. Le passage à l’éditeur de traduction de WPML écrasera la traduction existante."

msgid "This item needs a translation update but was previously translated using the WordPress Editor. Using the WPML's Translation Editor will overwrite the existing translation."
msgstr "Cet élément nécessite une mise à jour de traduction mais a été précédemment traduit à l’aide de l’éditeur WordPress. L’utilisation de l’éditeur de traduction de WPML écrasera la traduction existante."

msgid "This item hasn't been translated yet and is set to use the WordPress Editor."
msgstr "Cet élément n’a pas encore été traduit et est configuré pour utiliser l’éditeur WordPress."

