msgid "Alias Domain"
msgstr "Ψευδώνυμο τομέα"

msgid "If you didn't change your main domain and only logged in through an alias domain, you can register it here. WPML will then use the original domain for API communication with AMS."
msgstr "Εάν δεν αλλάξατε τον κύριο τομέα σας και συνδεθήκατε μόνο μέσω ενός ψευδώνυμου τομέα, μπορείτε να τον καταχωρίσετε εδώ. Το WPML θα χρησιμοποιήσει τότε τον αρχικό τομέα για επικοινωνία API με το AMS."

msgid "Something went wrong. Please try again."
msgstr "Κάτι πήγε στραβά. Παρακαλώ δοκιμάστε ξανά."

msgid "Registering..."
msgstr "Καταχωρίζεται..."

msgid "Register current domain as alias"
msgstr "Καταχωρίστε τον τρέχοντα τομέα ως ψευδώνυμο"

msgid "The current domain has been registered as an alias domain."
msgstr "Ο τρέχων τομέας έχει καταχωριστεί ως ψευδώνυμο τομέα."

msgid "Current alias domains:"
msgstr "Τρέχοντες ψευδώνυμοι τομείς:"

msgid "This will remove all registered alias domains. If you are accessing this site through an alias domain, the migration banner will appear again."
msgstr "Αυτό θα καταργήσει όλους τους καταχωρισμένους ψευδώνυμους τομείς. Εάν έχετε πρόσβαση σε αυτόν τον ιστότοπο μέσω ενός ψευδώνυμου τομέα, το banner μετανάστευσης θα εμφανιστεί ξανά."

msgid "Resetting..."
msgstr "Επαναφορά..."

msgid "Reset alias domains"
msgstr "Επαναφορά ψευδώνυμων τομέων"

msgid "Alias domains have been reset."
msgstr "Οι ψευδώνυμοι τομείς έχουν επαναφερθεί."

msgid "PostHog Integration"
msgstr "Ενσωμάτωση PostHog"

msgid "PostHog is running on your site"
msgstr "Το PostHog εκτελείται στον ιστότοπό σας"

msgid "Enable PostHog to help us improve our product"
msgstr "Ενεργοποιήστε το PostHog για να μας βοηθήσετε να βελτιώσουμε το προϊόν μας"

msgid "your PostHog session ID is: "
msgstr "το αναγνωριστικό συνεδρίας PostHog είναι: "
