msgstr "선택한 문자열 중 일부는 이미 %s에 등록되거나 번역되었습니다. 원본 언어가 대상 언어와 일치하므로 다시 번역할 수 없습니다."

msgid "Some of the selected content has already been translated from %s to %s and cannot be re-translated from %s to %s."
msgstr "선택한 콘텐츠 중 일부는 이미 %s에서 %s으로 번역되었으며 %s에서 %s으로 다시 번역할 수 없습니다."

msgid "Content already translated"
msgstr "이미 번역된 콘텐츠"

msgid "Some content couldn't be sent to translation."
msgstr "일부 콘텐츠를 번역으로 보낼 수 없습니다."

msgid "WPML did not create translations for some languages because of the following reasons:"
msgstr "WPML이 다음 이유로 일부 언어에 대한 번역을 생성하지 못했습니다:"

msgid "<s>1 item</s> has been successfully sent to translators!"
msgid_plural "<s>%d items</s> have been successfully sent to translators!"
msgstr[0] "<s>%d개 항목</s>이 번역가에게 성공적으로 전송되었습니다!"

msgid "Local translations summary"
msgstr "로컬 번역 요약"

msgid "You can check their status in WPML → Translation"
msgstr "WPML → 번역에서 상태를 확인할 수 있습니다."

msgid "Continue to %s"
msgstr "%s으로 계속"

