msgstr "자동 번역 - 일시 중지됨"

msgid "%d translation left in the queue. Preparing more content for translation."
msgid_plural "%d translations left in the queue. Preparing more content for translation."
msgstr[0] "대기열에 %d개 번역이 남아 있습니다. 번역을 위한 더 많은 콘텐츠를 준비 중입니다."

msgid "Preparing content for translation..."
msgstr "번역을 위해 콘텐츠 준비 중..."

msgid "%d translation left in the queue..."
msgid_plural "%d translations left in the queue..."
msgstr[0] "대기열에 %d개 번역이 남아 있습니다..."

msgid "Translate Everything Automatically has finished translating your content. There are no pending translations in the queue."
msgstr "자동 번역이 콘텐츠 번역을 완료했습니다. 대기열에 보류 중인 번역이 없습니다."

msgid "Some items were translated using the Classic Translation Editor and cannot be sent for automatic translation. Please select these items and choose the option to translate them yourself."
msgstr "일부 항목은 클래식 번역 편집기를 사용하여 번역되었으므로 자동 번역으로 보낼 수 없습니다. 이 항목들을 선택하고 직접 번역하는 옵션을 선택하세요."

msgid "Translate Everything Automatically - enabled"
msgstr "자동 번역 - 활성화됨"

msgid "Translate Everything Automatically is enabled"
msgstr "자동 번역이 활성화되었습니다."

msgid "As you create new content or edit existing content, WPML will automatically translate it, but only from %s to %s."
msgstr "새 콘텐츠를 생성하거나 기존 콘텐츠를 편집하면 WPML이 자동으로 번역하지만, %s에서 %s으로만 번역합니다."

msgid "Translate Everything Automatically is paused — payment required"
msgstr "모든 항목 자동 번역 일시 중지됨 — 결제 필요"

msgid "Automatic translation is paused — payment required"
msgstr "자동 번역 일시 중지됨 — 결제 필요"

msgid "Automatic translation - payment required"
msgstr "자동 번역 - 결제 필요"

msgid "We couldn’t process payment for your completed translations. Click “Pay now” to retry and continue using automatic translation."
msgstr "완료된 번역에 대한 결제를 처리할 수 없습니다. “지금 결제” 를 클릭하여 다시 시도하고 자동 번역을 계속 사용하세요."

msgid "Cancel translation"
msgstr "번역 취소"

msgid "Translate Everything Automatically is paused — not enough credits"
msgstr "모든 항목 자동 번역 일시 중지됨 — 크레딧 부족"

msgid "Automatic translation is paused — not enough credits"
msgstr "자동 번역 일시 중지됨 — 크레딧 부족"

msgid "Translation will resume automatically after you assign more credits."
msgstr "더 많은 크레딧을 할당하면 번역이 자동으로 다시 시작됩니다."

msgid "This item needs a translation update but can't be translated automatically because it was translated with the Classic Translation Editor."
msgstr "이 항목은 번역 업데이트가 필요하지만 클래식 번역 편집기로 번역되었기 때문에 자동으로 번역할 수 없습니다."

msgid "This item needs update. Please, select the item and send for translation."
msgstr "이 항목은 업데이트가 필요합니다. 항목을 선택하고 번역으로 보내세요."

msgid "Translations completed with the Classic Translation Editor cannot be sent for automatic translation"
msgstr "클래식 번역 편집기로 완료된 번역은 자동 번역으로 보낼 수 없습니다."

msgid "automatic translation"
msgstr "자동 번역"

msgid "unassigned"
msgstr "할당되지 않음"

msgid "not translated"
msgstr "번역되지 않음"

msgid "waiting for translator"
msgstr "번역가 대기 중"

msgid "in progress"
msgstr "진행 중"

msgid "needs update"
msgstr "업데이트 필요"

msgid "duplicate"
msgstr "복제"

msgid "complete"
msgstr "완료"

msgid "needs review"
msgstr "검토 필요"

msgid "preparing for translation"
msgstr "번역 준비 중"

msgid "needs attention"
msgstr "주의 필요"

msgid "translation error"
msgstr "번역 오류"

msgid "This item was translated using the WordPress Editor. Switching to the WPML's Translation Editor will overwrite the existing translation."
msgstr "이 항목은 WordPress 편집기를 사용하여 번역되었습니다. WPML의 번역 편집기로 전환하면 기존 번역이 덮어쓰여집니다."

msgid "This item needs a translation update but was previously translated using the WordPress Editor. Using the WPML's Translation Editor will overwrite the existing translation."
msgstr "이 항목은 번역 업데이트가 필요하지만 이전에 WordPress 편집기를 사용하여 번역되었습니다. WPML의 번역 편집기를 사용하면 기존 번역이 덮어쓰여집니다."

msgid "This item hasn't been translated yet and is set to use the WordPress Editor."
msgstr "이 항목은 아직 번역되지 않았으며 WordPress 편집기를 사용하도록 설정되어 있습니다."

msgid "%1$s: %2$s%3$s"
msgstr "%1$s: %2$s%3$s"

msgid "Could not fetch engines data"
msgstr "엔진 데이터를 가져올 수 없습니다."

msgid "Error in fetching currently logged in translator"
msgstr "현재 로그인한 번역가를 가져오는 중 오류 발생"

msgid "Error in fetching local translators"
msgstr "로컬 번역가를 가져오는 중 오류 발생"

msgid "Published"
msgstr "게시됨"

msgid "Draft"
msgstr "초안"

msgid "Trash"
msgstr "휴지통"

msgid "Pending"
msgstr "대기 중"

msgid "Private"
msgstr "비공개"

msgid "Future"
msgstr "미래"

msgid "Auto Draft"
msgstr "자동 초안"

msgid "External"
msgstr "외부"

msgid "Collapse"
msgstr "접기"

msgid "Expand"
msgstr "확장"

msgid "Select an item"
msgstr "항목 선택"

msgid "Open dropdown"
msgstr "드롭다운 열기"

msgid "Reset"
msgstr "재설정"

msgid "Search"
msgstr "검색"

msgid "No items found"
msgstr "항목을 찾을 수 없습니다."

msgid "OFF"
msgstr "끔"

msgid "ON"
msgstr "켬"

msgid "%1$s Flag"
msgstr "%1$s 플래그"

msgid "- Select a review mode -"
msgstr "- 검토 모드 선택 -"

msgid "What would you like to do when WPML finishes translating your content automatically?"
msgstr "WPML이 콘텐츠 자동 번역을 완료하면 어떻게 하시겠습니까?"

msgid "What would you like to do after WPML finishes translating your content automatically?"
msgstr "WPML이 콘텐츠 자동 번역을 완료한 후 어떻게 하시겠습니까?"

msgid "Publish without review"
msgstr "검토 없이 게시"

msgid "Recommended with PTC"
msgstr "PTC 사용 권장"

msgid "PTC provides Better Than Human Translations that rarely need improvements, so you can confidently skip the review process. For other translation engines, a human review is recommended to confirm accuracy."
msgstr "PTC는 개선이 거의 필요 없는 인간보다 더 나은 번역을 제공하므로, 검토 과정을 자신 있게 건너뛸 수 있습니다. 다른 번역 엔진의 경우 정확성을 확인하기 위해 인간 검토를 권장합니다."

msgid "WPML publishes translations immediately, skipping the review process."
msgstr "WPML은 검토 과정을 건너뛰고 번역을 즉시 게시합니다."

msgid "Wait for review"
msgstr "검토 대기"

msgid "Recommended with DeepL, Google and Microsoft"
msgstr "DeepL, Google, Microsoft 사용 권장"

msgid "DeepL, Google, and Microsoft deliver great translations, but we recommend a human review to confirm they are correct. PTC provides Better Than Human Translations that understand context, so you can confidently skip the review process."
msgstr "DeepL, Google, Microsoft는 훌륭한 번역을 제공하지만, 정확성을 확인하기 위해 인간 검토를 권장합니다. PTC는 컨텍스트를 이해하는 인간보다 더 나은 번역을 제공하므로, 검토 과정을 자신 있게 건너뛸 수 있습니다."

msgid "WPML keeps translations unpublished, so you can review them first."
msgstr "WPML은 번역을 게시하지 않고, 먼저 검토할 수 있도록 유지합니다."

msgid "Your translators review and approve translations before publishing."
msgstr "번역가가 게시하기 전에 번역을 검토하고 승인합니다."

msgid "Publish and mark for review"
msgstr "게시 및 검토 표시"

msgid "WPML publishes translations immediately but flags them for you to check at your convenience."
msgstr "WPML은 번역을 즉시 게시하지만, 편리할 때 확인할 수 있도록 플래그를 지정합니다."

msgid "WPML publishes translations immediately but flags them for translators to review later."
msgstr "WPML은 번역을 즉시 게시하지만 나중에 번역가가 검토하도록 플래그를 지정합니다."
