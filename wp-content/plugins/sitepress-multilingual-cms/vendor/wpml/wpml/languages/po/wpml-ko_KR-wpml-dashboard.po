msgstr "전문 번역을 위해 다음 배치를 보낼 수 없었습니다:"

msgid "<p><a><s>Contact WPML support for help</s></a></p>"
msgstr "<p><a><s>WPML 지원팀에 문의하여 도움을 받으세요</s></a></p>"

msgid "Translation Service"
msgstr "번역 서비스"

