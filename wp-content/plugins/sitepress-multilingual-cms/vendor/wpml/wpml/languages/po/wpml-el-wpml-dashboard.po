msgid "The following target languages do not support automatic translation: %s. <a>Map to known languages</a> to enable automatic translation."
msgstr "Οι ακόλουθες γλώσσες-στόχοι δεν υποστηρίζουν αυτόματη μετάφραση: %s. <a>Αντιστοίχιση σε γνωστές γλώσσες</a> για να ενεργοποιηθεί η αυτόματη μετάφραση."

msgid "The site's default language %s doesn't support automatic translation."
msgstr "Η προεπιλεγμένη γλώσσα του ιστότοπου %s δεν υποστηρίζει αυτόματη μετάφραση."

msgid "Some sections are hidden due to current filter settings or because they have no items. <show_all>Show all translation statuses</show_all>"
msgstr "Ορισμένες ενότητες είναι κρυφές λόγω των τρεχουσών ρυθμίσεων φίλτρου ή επειδή δεν έχουν στοιχεία. <show_all>Εμφάνιση όλων των καταστάσεων μετάφρασης</show_all>"

msgid "Step 1"
msgstr "Βήμα 1"

msgid "Select items for translation"
msgstr "Επιλέξτε στοιχεία για μετάφραση"

