msgstr "Το WPML θα μεταφράσει το περιεχόμενό σας σε %d γλώσσες"

msgid "You can start using Translate Everything Automatically after sending some content for translation. We recommend that you review these translations and make sure that they are good before translating your entire site's content."
msgstr "Μπορείτε να αρχίσετε να χρησιμοποιείτε την Αυτόματη Μετάφραση Όλων αφού στείλετε κάποιο περιεχόμενο για μετάφραση. Σας συνιστούμε να ελέγξετε αυτές τις μεταφράσεις και να βεβαιωθείτε ότι είναι καλές πριν μεταφράσετε ολόκληρο το περιεχόμενο του ιστοτόπου σας."

msgid "Translate Everything Automatically - disabled"
msgstr "Αυτόματη Μετάφραση Όλων - απενεργοποιημένη"

msgid "Translate Everything Automatically"
msgstr "Αυτόματη μετάφραση όλων"

msgid "Automatically translate all %s content to %s."
msgstr "Αυτόματη μετάφραση όλου του περιεχομένου %s σε %s."

msgid "Translate Everything Automatically - pausing"
msgstr "Αυτόματη Μετάφραση Όλων - σε παύση"

msgid "Translate Everything Automatically is pausing"
msgstr "Η Αυτόματη Μετάφραση Όλων είναι σε παύση"

msgid "Translate Everything Automatically - paused"
msgstr "Αυτόματη Μετάφραση Όλων - σε παύση"

msgid "%d translation left in the queue. Preparing more content for translation."
msgid_plural "%d translations left in the queue. Preparing more content for translation."
msgstr[0] "%d μετάφραση έχει απομείνει στην ουρά. Προετοιμάζεται περισσότερο περιεχόμενο για μετάφραση."
msgstr[1] "%d μεταφράσεις έχουν απομείνει στην ουρά. Προετοιμάζεται περισσότερο περιεχόμενο για μετάφραση."

msgid "Preparing content for translation..."
msgstr "Προετοιμασία περιεχομένου για μετάφραση..."

msgid "%d translation left in the queue..."
msgid_plural "%d translations left in the queue..."
msgstr[0] "%d μετάφραση έχει απομείνει στην ουρά..."
msgstr[1] "%d μεταφράσεις έχουν απομείνει στην ουρά..."

msgid "Translate Everything Automatically has finished translating your content. There are no pending translations in the queue."
msgstr "Η Αυτόματη Μετάφραση Όλων ολοκλήρωσε τη μετάφραση του περιεχομένου σας. Δεν υπάρχουν εκκρεμείς μεταφράσεις στην ουρά."

msgid "Some items were translated using the Classic Translation Editor and cannot be sent for automatic translation. Please select these items and choose the option to translate them yourself."
msgstr "Ορισμένα στοιχεία μεταφράστηκαν χρησιμοποιώντας τον Κλασικό Επεξεργαστή Μετάφρασης και δεν μπορούν να σταλούν για αυτόματη μετάφραση. Παρακαλούμε επιλέξτε αυτά τα στοιχεία και επιλέξτε την επιλογή να τα μεταφράσετε μόνοι σας."

msgid "Translate Everything Automatically - enabled"
msgstr "Αυτόματη Μετάφραση Όλων - ενεργοποιημένη"

msgid "Translate Everything Automatically is enabled"
msgstr "Η Αυτόματη Μετάφραση Όλων είναι ενεργοποιημένη"

msgid "As you create new content or edit existing content, WPML will automatically translate it, but only from %s to %s."
msgstr "Καθώς δημιουργείτε νέο περιεχόμενο ή επεξεργάζεστε υπάρχον περιεχόμενο, το WPML θα το μεταφράζει αυτόματα, αλλά μόνο από %s σε %s."

msgid "Translate Everything Automatically is paused — payment required"
msgstr "Η αυτόματη μετάφραση όλων τέθηκε σε παύση — απαιτείται πληρωμή"

msgid "Automatic translation is paused — payment required"
msgstr "Η αυτόματη μετάφραση τέθηκε σε παύση — απαιτείται πληρωμή"

msgid "Automatic translation - payment required"
msgstr "Αυτόματη μετάφραση - απαιτείται πληρωμή"

msgid "We couldn’t process payment for your completed translations. Click “Pay now” to retry and continue using automatic translation."
msgstr "Δεν μπορέσαμε να επεξεργαστούμε την πληρωμή για τις ολοκληρωμένες μεταφράσεις σας. Κάντε κλικ στο “Πληρώστε τώρα” για να δοκιμάσετε ξανά και να συνεχίσετε να χρησιμοποιείτε την αυτόματη μετάφραση."

msgid "Cancel translation"
msgstr "Ακύρωση μετάφρασης"

msgid "Translate Everything Automatically is paused — not enough credits"
msgstr "Η αυτόματη μετάφραση όλων τέθηκε σε παύση — δεν υπάρχουν αρκετές πιστώσεις"

msgid "Automatic translation is paused — not enough credits"
msgstr "Η αυτόματη μετάφραση τέθηκε σε παύση — δεν υπάρχουν αρκετές πιστώσεις"

msgid "Translation will resume automatically after you assign more credits."
msgstr "Η μετάφραση θα συνεχιστεί αυτόματα αφού αναθέσετε περισσότερες πιστώσεις."

msgid "This item needs a translation update but can't be translated automatically because it was translated with the Classic Translation Editor."
msgstr "Αυτό το στοιχείο χρειάζεται ενημέρωση μετάφρασης, αλλά δεν μπορεί να μεταφραστεί αυτόματα επειδή μεταφράστηκε με τον Κλασικό Επεξεργαστή Μετάφρασης."

msgid "This item needs update. Please, select the item and send for translation."
msgstr "Αυτό το στοιχείο χρειάζεται ενημέρωση. Παρακαλούμε, επιλέξτε το στοιχείο και στείλτε το για μετάφραση."

msgid "Translations completed with the Classic Translation Editor cannot be sent for automatic translation"
msgstr "Οι μεταφράσεις που ολοκληρώθηκαν με τον Κλασικό Επεξεργαστή Μετάφρασης δεν μπορούν να σταλούν για αυτόματη μετάφραση"

