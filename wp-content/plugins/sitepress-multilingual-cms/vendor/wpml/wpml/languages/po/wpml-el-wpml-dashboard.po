msgid "Your site's content is too vast for a single translation batch. Use filters to reduce the selection, then \"select all\"."
msgstr "Το περιεχόμενο του ιστότοπού σας είναι πολύ μεγάλο για μία μόνο παρτίδα μετάφρασης. Χρησιμοποιήστε φίλτρα για να μειώσετε την επιλογή και, στη συνέχεια, “επιλέξτε όλα”."

msgid "The current filter captures too much content. Narrow it down to enable \"select all\" for translation."
msgstr "Το τρέχον φίλτρο καταγράφει υπερβολικά πολύ περιεχόμενο. Περιορίστε το για να ενεργοποιήσετε την επιλογή “επιλογή όλων” για μετάφραση."

msgid "Select All"
msgstr "Επιλογή όλων"

msgid "All %d items matching criteria are selected"
msgstr "Έχουν επιλεγεί όλα τα %d στοιχεία που ταιριάζουν με τα κριτήρια"

msgid "All %d items in this section are selected"
msgstr "Έχουν επιλεγεί όλα τα %d στοιχεία σε αυτήν την ενότητα"

msgid "You have too many items to send for translation at once. Apply a filter to narrow down the items to enable this option."
msgstr "Έχετε επιλέξει πάρα πολλά στοιχεία για αποστολή προς μετάφραση ταυτόχρονα. Εφαρμόστε ένα φίλτρο για να περιορίσετε τα στοιχεία ώστε να ενεργοποιηθεί αυτή η επιλογή."

msgid "Clear selection"
msgstr "Εκκαθάριση επιλογής"

msgid "Select all items that match this search"
msgstr "Επιλέξτε όλα τα στοιχεία που ταιριάζουν με αυτήν την αναζήτηση"

