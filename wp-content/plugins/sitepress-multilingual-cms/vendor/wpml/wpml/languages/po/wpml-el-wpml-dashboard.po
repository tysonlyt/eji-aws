msgid "translation error"
msgstr "σφάλμα μετάφρασης"

msgid "This item was translated using the WordPress Editor. Switching to the WPML's Translation Editor will overwrite the existing translation."
msgstr "Αυτό το στοιχείο μεταφράστηκε χρησιμοποιώντας τον Επεξεργαστή του WordPress. Η μετάβαση στον Επεξεργαστή Μετάφρασης του WPML θα αντικαταστήσει την υπάρχουσα μετάφραση."

msgid "This item needs a translation update but was previously translated using the WordPress Editor. Using the WPML's Translation Editor will overwrite the existing translation."
msgstr "Αυτό το στοιχείο χρειάζεται ενημέρωση μετάφρασης, αλλά είχε προηγουμένως μεταφραστεί χρησιμοποιώντας τον Επεξεργαστή του WordPress. Η χρήση του Επεξεργαστή Μετάφρασης του WPML θα αντικαταστήσει την υπάρχουσα μετάφραση."

msgid "This item hasn't been translated yet and is set to use the WordPress Editor."
msgstr "Αυτό το στοιχείο δεν έχει μεταφραστεί ακόμα και έχει οριστεί να χρησιμοποιεί τον Επεξεργαστή του WordPress."

