msgid "Could not fetch engines data"
msgstr "Không thể tìm nạp dữ liệu công cụ"

msgid "Could not save settings"
msgstr "Không thể lưu cài đặt"

msgid "Automatic translation"
msgstr "Dịch tự động"

msgid "Saving..."
msgstr "Đang lưu..."

msgid "Save settings"
msgstr "Lưu cài đặt"

msgid "Settings saved"
msgstr "Đã lưu cài đặt"

msgid "Some error occurred"
msgstr "Đã xảy ra lỗi"

msgid "AI Translation"
msgstr "Dịch thuật AI"

msgid "Don't translate drafts. Only translate when I publish content."
msgstr "Không dịch bản nháp. Chỉ dịch khi tôi xuất bản nội dung."

msgid "Translate drafts as I save them (consumes a bit more translation credits)."
msgstr "Dịch bản nháp khi tôi lưu chúng (tiêu tốn thêm một chút tín dụng dịch thuật)."

msgid "Do you want to translate drafts automatically?"
msgstr "Bạn có muốn dịch bản nháp tự động không?"

msgid "This feature is only available when you enable \"Translate Everything Automatically\" from the %sTranslation Dashboard%s."
msgstr "Tính năng này chỉ khả dụng khi bạn bật “Dịch mọi thứ tự động” từ %sBảng điều khiển dịch thuật%s."

msgid "What would you like to do after WPML finishes translating your content automatically?"
msgstr "Bạn muốn làm gì sau khi WPML hoàn tất dịch nội dung của bạn tự động?"

msgid "Publish without review"
msgstr "Xuất bản mà không cần xem xét"

msgid "Recommended with PTC"
msgstr "Được khuyến nghị với PTC"

msgid "PTC provides Better Than Human Translations that rarely need improvements, so you can confidently skip the review process. For other translation engines, a human review is recommended to confirm accuracy."
msgstr "PTC cung cấp bản dịch tốt hơn con người, hiếm khi cần cải thiện, vì vậy bạn có thể tự tin bỏ qua quá trình xem xét. Đối với các công cụ dịch thuật khác, nên xem xét thủ công để xác nhận độ chính xác."

msgid "WPML publishes translations immediately, skipping the review process."
msgstr "WPML xuất bản bản dịch ngay lập tức, bỏ qua quá trình xem xét."

msgid "Wait for review"
msgstr "Chờ xem xét"

msgid "Recommended with DeepL, Google and Microsoft"
msgstr "Được khuyến nghị với DeepL, Google và Microsoft"

msgid "DeepL, Google, and Microsoft deliver great translations, but we recommend a human review to confirm they are correct. PTC provides Better Than Human Translations that understand context, so you can confidently skip the review process."
msgstr "DeepL, Google và Microsoft cung cấp bản dịch tuyệt vời, nhưng chúng tôi khuyên bạn nên xem xét thủ công để xác nhận chúng chính xác. PTC cung cấp bản dịch tốt hơn con người, hiểu ngữ cảnh, vì vậy bạn có thể tự tin bỏ qua quá trình xem xét."

msgid "WPML keeps translations unpublished, so you can review them first."
msgstr "WPML giữ bản dịch chưa xuất bản, để bạn có thể xem xét chúng trước."

msgid "Your translators review and approve translations before publishing."
msgstr "Người dịch của bạn xem xét và phê duyệt bản dịch trước khi xuất bản."

msgid "Publish and mark for review"
msgstr "Xuất bản và đánh dấu để xem xét"

msgid "WPML publishes translations immediately but flags them for you to check at your convenience."
msgstr "WPML xuất bản bản dịch ngay lập tức nhưng gắn cờ để bạn kiểm tra vào lúc thuận tiện."

msgid "WPML publishes translations immediately but flags them for translators to review later."
msgstr "WPML xuất bản bản dịch ngay lập tức nhưng gắn cờ để người dịch xem xét sau."
