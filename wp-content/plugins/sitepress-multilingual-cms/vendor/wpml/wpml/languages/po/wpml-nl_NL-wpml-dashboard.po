msgid "In order to assign yourself as translator, you first need to <add_yourself>add yourself as %s translator</add_yourself> to the site.<br/> Add yourself as %s translator and click <check_again>check again</check_again> or choose a different translation option."
msgstr "Om uzelf als vertaler toe te wijzen, moet u uzelf eerst <add_yourself>toevoegen als %s vertaler</add_yourself> aan de site.<br/> Voeg uzelf toe als %s vertaler en klik op <check_again>opnieuw controleren</check_again> of kies een andere vertaaloptie."

msgid "In order to assign yourself as translator, you first need to <add_yourself>add yourself as %s to %s translator</add_yourself> to the site.<br/> Add yourself as %s to %s translator and click <check_again>check again</check_again> or choose a different translation option."
msgstr "Om uzelf als vertaler toe te wijzen, moet u uzelf eerst <add_yourself>toevoegen als %s aan %s vertaler</add_yourself> aan de site.<br/> Voeg uzelf toe als %s aan %s vertaler en klik op <check_again>opnieuw controleren</check_again> of kies een andere vertaaloptie."

msgid "Checking"
msgstr "Controleren"

msgid "In order to assign a translation service, you first need to <activate_ts>activate a translation service</activate_ts>.<br/>Activate a translation service and click <check_again>check again</check_again> or choose a different translation option."
msgstr "Om een vertaalservice toe te wijzen, moet u eerst <activate_ts>een vertaalservice activeren</activate_ts>.<br/>Activeer een vertaalservice en klik op <check_again>opnieuw controleren</check_again> of kies een andere vertaaloptie."

msgid " Checking "
msgstr " Controleren "

msgid "In order to translate automatically, you first need to <enable_ate>enable WPML's Advanced Translation Editor</enable_ate>.<br/>Enable the Advanced Translation Editor and click <check_again>check again</check_again> or choose a different translation option."
msgstr "Om automatisch te vertalen, moet u eerst <enable_ate>WPML's Geavanceerde Vertaaleditor inschakelen</enable_ate>.<br/>Schakel de Geavanceerde Vertaaleditor in en klik op <check_again>opnieuw controleren</check_again> of kies een andere vertaaloptie."

msgid "Selected content was translated using the Classic Translation Editor and can't be sent for automatic translation. To allow this, enable \"Use also for old translations\" in <wpmlSettingLink>WPML Settings</wpmlSettingLink> page."
msgstr "Geselecteerde inhoud is vertaald met de Klassieke Vertaaleditor en kan niet worden verzonden voor automatische vertaling. Om dit toe te staan, schakelt u “Ook gebruiken voor oude vertalingen” in op de pagina <wpmlSettingLink>WPML-instellingen</wpmlSettingLink>."

msgid "Some of the selected content was translated using the Classic Translation Editor and can't be sent for automatic translation. To allow this, enable \"Use also for old translations\" in <wpmlSettingLink>WPML Settings</wpmlSettingLink> page."
msgstr "Een deel van de geselecteerde inhoud is vertaald met de Klassieke Vertaaleditor en kan niet worden verzonden voor automatische vertaling. Om dit toe te staan, schakelt u “Ook gebruiken voor oude vertalingen” in op de pagina <wpmlSettingLink>WPML-instellingen</wpmlSettingLink>."

