msgstr[0] "%d vertaling over in de wachtrij..."
msgstr[1] "%d vertalingen over in de wachtrij..."

msgid "Translate Everything Automatically has finished translating your content. There are no pending translations in the queue."
msgstr "Alles automatisch vertalen is klaar met het vertalen van uw inhoud. Er staan geen vertalingen meer in de wachtrij."

msgid "Some items were translated using the Classic Translation Editor and cannot be sent for automatic translation. Please select these items and choose the option to translate them yourself."
msgstr "Sommige items zijn vertaald met de Klassieke Vertaal-editor en kunnen niet automatisch worden vertaald. Selecteer deze items en kies de optie om ze zelf te vertalen."

msgid "Translate Everything Automatically - enabled"
msgstr "Alles automatisch vertalen - ingeschakeld"

msgid "Translate Everything Automatically is enabled"
msgstr "Alles automatisch vertalen is ingeschakeld"

msgid "As you create new content or edit existing content, WPML will automatically translate it, but only from %s to %s."
msgstr "Wanneer u nieuwe inhoud maakt of bestaande inhoud bewerkt, vertaalt WPML deze automatisch, maar alleen van %s naar %s."

msgid "Translate Everything Automatically is paused — payment required"
msgstr "Alles automatisch vertalen is gepauzeerd — betaling vereist"

msgid "Automatic translation is paused — payment required"
msgstr "Automatische vertaling is gepauzeerd — betaling vereist"

msgid "Automatic translation - payment required"
msgstr "Automatische vertaling - betaling vereist"

msgid "We couldn’t process payment for your completed translations. Click “Pay now” to retry and continue using automatic translation."
msgstr "We konden de betaling voor uw voltooide vertalingen niet verwerken. Klik op “Nu betalen” om het opnieuw te proberen en de automatische vertaling te blijven gebruiken."

msgid "Cancel translation"
msgstr "Vertaling annuleren"

msgid "Translate Everything Automatically is paused — not enough credits"
msgstr "Alles automatisch vertalen is gepauzeerd — niet genoeg tegoeden"

