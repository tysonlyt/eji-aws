msgstr "Alles automatisch vertalen - pauzeren"

msgid "Translate Everything Automatically is pausing"
msgstr "Alles automatisch vertalen wordt gepauzeerd"

msgid "Translate Everything Automatically - paused"
msgstr "Alles automatisch vertalen - gepauzeerd"

msgid "%d translation left in the queue. Preparing more content for translation."
msgid_plural "%d translations left in the queue. Preparing more content for translation."
msgstr[0] "%d vertaling over in de wachtrij. Meer inhoud wordt voorbereid voor vertaling."
msgstr[1] "%d vertalingen over in de wachtrij. Meer inhoud wordt voorbereid voor vertaling."

